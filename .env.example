# EmailJS Configuration
# Copy this file to .env.local and replace with your actual credentials
VITE_EMAILJS_SERVICE_ID=your_service_id_here
VITE_EMAILJS_PUBLIC_KEY=your_public_api_key_here

# EmailJS Template IDs
# Replace these with your actual template IDs from EmailJS dashboard
VITE_EMAILJS_CLIENT_TEMPLATE_ID=your_client_template_id_here
VITE_EMAILJS_STAFF_TEMPLATE_ID=your_staff_template_id_here
