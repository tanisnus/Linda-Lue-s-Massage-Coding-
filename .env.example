# Resend Email Configuration (server-side only — do NOT prefix with VITE_)
# Copy this file to .env.local for local development
# Set these in Vercel Dashboard → Settings → Environment Variables for production

RESEND_API_KEY=
RESEND_FROM_EMAIL=

# Recipient emails (kept server-side, not exposed to the browser)
# SHOP_EMAIL receives staff booking notifications (primary recipient)
SHOP_EMAIL=
# THERAPIST_EMAIL also receives staff notifications when different from SHOP_EMAIL
THERAPIST_EMAIL=

# Public site URL used in cancellation links (optional)
BOOKING_SITE_URL=https://www.lindalueswellnessandspa.com
# Secret for signing cancellation links (optional — falls back to RESEND_API_KEY)
BOOKING_CANCEL_SECRET=

# Google Calendar (optional — enables live slot availability + auto-add bookings)
# Share the shop calendar with GOOGLE_CLIENT_EMAIL (service account)
# Permission required: "Make changes to events" (not read-only)
GOOGLE_CLIENT_EMAIL=
GOOGLE_PRIVATE_KEY=
GOOGLE_CALENDAR_ID=
